// ===============================================
// PRISMA SCHEMA - DEPARTAMENTO ESTADUAL DE RODOVIAS (Sistema de Gestão)
// ===============================================
// Modelos, enums e campos em inglês; comentários em português.
// Sem @map: nomes das colunas = camelCase no banco.
// ===============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===============================================
// ENUMS - ROLES E USUÁRIOS
// ===============================================

enum Roles {
  SYSTEM_ADMIN // Administrador da plataforma
  ADMIN // Admin geral - acesso total
  FIELD_TEAM // Equipe de Campo - Fiscalização e relatórios de localidades (Técnico)
  C2C // C2C - Centro de Controle e Comando
}

enum UserStatus {
  ACTIVE // Ativo
  INACTIVE // Inativo
  PENDING // Pendente
}

enum PermissionType {
  REPORTS // Relatórios
  INSPETOR_VIA // Motorista
}

// ===============================================
// ENUMS - DOMÍNIO DEPARTAMENTO ESTADUAL DE RODOVIAS
// ===============================================

enum AssetType {
  CAMERA // Câmera
  ATDB // ATDB
  TMV // TMV
  OTHER // Outro
}

enum AssetConnectionType {
  API
  WEBHOOK
}

enum AssetStatus {
  ONLINE // Operacional
  OFFLINE // Offline
  CRITICAL // Falha crítica
  WARNING // Atenção
}

enum AssetCriticality {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum RegionalStatus {
  ACTIVE
  INACTIVE
}

enum WorkOrderPriority {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum WorkOrderStatus {
  PENDING
  ASSIGNED
  IN_PROGRESS
  PAUSED
  COMPLETED
  CANCELLED
}

enum WorkOrderType {
  PREVENTIVE
  CORRECTIVE
  TECHNICAL_REVIEW
}

enum WorkOrderSlaStatus {
  OK
  WARNING
  OVERDUE
}

// ===============================================
// ARQUIVOS E DOCUMENTOS
// ===============================================

enum FileType {
  PROFILE_IMAGE
  DOCUMENT
  REPORT
  VIDEO
  AUDIO
  OTHER
}

enum DocumentRecipientType {
  HR
  SUPERVISOR
  ADMIN
}

enum DocumentStatus {
  PENDING
  VIEWED
  DOWNLOADED
}

enum NotificationGroupType {
  ROLE
  SECTOR
  CUSTOM
}

enum NotificationTargetType {
  USER
  ROLE
  GROUP
  COMPANY
  CUSTOM
}

// ===============================================
// EMPRESA E MULTI-TENANCY
// ===============================================

model Company {
  id           String  @id @default(cuid())
  name         String
  cnpj         String  @unique
  address      String?
  contactName  String?
  contactEmail String?
  contactPhone String?

  users            User[]
  assets           Asset[]
  locations        Location[]
  workOrders       WorkOrder[]
  regionals        Regional[]
  workOrderColumns WorkOrderColumn[]
  plannings        Planning[]

  files              File[]              @relation("CompanyFiles")
  documents          Document[]          @relation("CompanyDocuments")
  notifications      Notification[]      @relation("CompanyNotifications")
  notificationGroups NotificationGroup[] @relation("CompanyNotificationGroups")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([cnpj])
  @@index([name])
  @@index([deletedAt])
}

model User {
  id             String     @id @default(cuid())
  name           String
  email          String     @unique
  login          String     @unique
  password       String
  role           Roles
  function       String?
  profilePicture String?
  status         UserStatus @default(ACTIVE)
  phone          String?

  notificationEmail            Boolean @default(true)
  notificationPushNotification Boolean @default(true)
  activitiesNotification       Json?   @default("{\"assignments\": true, \"comments\": true, \"deadlines\": true, \"reports\": true }")

  companyId String
  company   Company? @relation(fields: [companyId], references: [id])

  regionalId String?
  regional   Regional? @relation(fields: [regionalId], references: [id], onDelete: SetNull)

  permissions             Permission[]
  oauthAccounts           OAuthAccount[]
  workOrderPauseHistories WorkOrderPauseHistory[]
  planningAssignments     PlanningResponsible[]
  files                   File[]                    @relation("UserFiles")
  documentsSent           Document[]                @relation("DocumentSender")
  notifications           NotificationRecipient[]   @relation("UserNotifications")
  groupMemberships        NotificationGroupMember[] @relation("UserGroupMemberships")
  pushSubscriptions       PushSubscription[]        @relation("UserPushSubscriptions")
  workOrderComments       WorkOrderComment[]        @relation("WorkOrderCommentsAuthor")
  assignees               WorkOrderAssignee[]       @relation("UserWorkOrderAssignee")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([companyId])
  @@index([email])
  @@index([status])
  @@index([deletedAt])
  @@index([role])
  @@index([createdAt])
}

// Contas OAuth vinculadas ao usuário (Google, Microsoft)
model OAuthAccount {
  id           String    @id @default(cuid())
  provider     String // "google" | "microsoft"
  providerId   String // ID único do provider
  accessToken  String?   @db.Text
  refreshToken String?   @db.Text
  expiresAt    DateTime?
  email        String?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([provider, providerId])
  @@index([userId])
  @@index([provider])
}

model Permission {
  id             String         @id @default(cuid())
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String
  permissionType PermissionType
  granted        Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@unique([userId, permissionType])
  @@index([userId])
  @@index([permissionType])
}

// ===============================================
// ATIVOS EM CAMPO (câmeras, sensores, equipamentos)
// ===============================================

model Asset {
  id              String               @id @default(cuid())
  companyId       String
  name            String
  code            String?
  type            AssetType
  km              Float
  direction       String
  status          AssetStatus          @default(ONLINE)
  criticality     AssetCriticality     @default(MEDIUM)
  latitude        Float?
  longitude       Float?
  lastSignalAt    DateTime?
  connectionType  AssetConnectionType?
  connectionUrl   String?
  connectionToken String?

  locationId String
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([companyId])
  @@index([locationId])
  @@index([status])
  @@index([criticality])
  @@index([connectionType])
  @@index([deletedAt])
}

// ===============================================
// REGIONAIS
// ===============================================

model Regional {
  id     String         @id @default(cuid())
  sgr    String
  city   String
  status RegionalStatus @default(ACTIVE)

  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId String

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  locations        Location[]
  users            User[]
  workOrderColumns WorkOrderColumn[]

  @@index([companyId])
  @@index([sgr])
  @@index([deletedAt])
}

// ===============================================
// RODOVIAS (LOCALIDADES)
// ===============================================

model Location {
  id          String         @id @default(cuid())
  code        String
  name        String
  uf          String
  referenceKm Float
  status      RegionalStatus @default(ACTIVE)
  ipAddresses Json?

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  regionalId String
  regional   Regional @relation(fields: [regionalId], references: [id], onDelete: Cascade)

  assets     Asset[]
  workOrders WorkOrder[]

  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  deletedAt DateTime?
  plannings Planning[]

  @@index([companyId])
  @@index([code])
  @@index([status])
  @@index([deletedAt])
}

model WorkOrderColumn {
  id         String  @id @default(cuid())
  name       String
  color      String
  sortOrder  Int     @default(0)
  isArchived Boolean @default(false)

  companyId  String
  company    Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  regionalId String?
  regional   Regional? @relation(fields: [regionalId], references: [id], onDelete: SetNull)

  workOrders WorkOrder[]
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  deletedAt  DateTime?

  @@index([id])
  @@index([companyId])
  @@index([sortOrder])
}

model WorkOrderAssignee {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation("UserWorkOrderAssignee", fields: [userId], references: [id], onDelete: Cascade)
  workOrderId String
  workOrder   WorkOrder @relation("WorkOrderAssignees", fields: [workOrderId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@unique([workOrderId, userId])
  @@index([userId])
  @@index([workOrderId])
}

// ===============================================
// ORDENS DE SERVIÇO (manutenção de ativos)
// ===============================================

model WorkOrder {
  id               String              @id @default(cuid())
  companyId        String
  locationId       String
  title            String
  description      String?
  priority         WorkOrderPriority
  status           WorkOrderStatus     @default(PENDING)
  type             WorkOrderType
  dueDate          DateTime?
  slaDeadlineHours Int?
  slaStatus        WorkOrderSlaStatus? @default(OK)
  equipmentType    AssetType?

  planningId String?   @unique
  planning   Planning? @relation(fields: [planningId], references: [id], onDelete: SetNull)

  columnId String?
  column   WorkOrderColumn? @relation(fields: [columnId], references: [id], onDelete: SetNull)

  company   Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  location  Location            @relation(fields: [locationId], references: [id], onDelete: Restrict)
  assignees WorkOrderAssignee[] @relation("WorkOrderAssignees")

  checklistItems WorkOrderChecklistItem[]
  comments       WorkOrderComment[]
  evidences      WorkOrderEvidence[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  createdBy               String?
  updatedBy               String?
  workOrderPauseHistories WorkOrderPauseHistory[]

  @@index([companyId])
  @@index([locationId])
  @@index([status])
  @@index([priority])
  @@index([dueDate])
  @@index([deletedAt])
}

model WorkOrderChecklistItem {
  id          String  @id @default(cuid())
  workOrderId String
  label       String
  isDone      Boolean @default(false)
  sortOrder   Int?

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workOrderId])
}

model WorkOrderComment {
  id          String @id @default(cuid())
  workOrderId String
  authorId    String
  text        String @db.Text

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  author    User      @relation("WorkOrderCommentsAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([workOrderId])
  @@index([authorId])
}

model WorkOrderEvidence {
  id          String  @id @default(cuid())
  workOrderId String
  fileId      String
  description String?

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  file      File      @relation("WorkOrderEvidenceFile", fields: [fileId], references: [id])

  createdAt DateTime @default(now())

  @@index([workOrderId])
  @@index([fileId])
}

model WorkOrderPauseHistory {
  id     String @id @default(cuid())
  reason String

  workOrderId String
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  pausedByUserId String
  pausedByUser   User   @relation(fields: [pausedByUserId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([workOrderId])
}

model Planning {
  id            String        @id @default(cuid())
  title         String
  date          DateTime
  serviceType   WorkOrderType
  equipmentType AssetType
  km            Float
  observation   String?

  locationId String
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  responsibles PlanningResponsible[]
  workOrder    WorkOrder?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([id])
  @@index([companyId])
  @@index([locationId])
}

model PlanningResponsible {
  id         String @id @default(cuid())
  planningId String
  userId     String

  planning Planning @relation(fields: [planningId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([planningId, userId])
  @@index([planningId])
  @@index([userId])
}

// ===============================================
// ARQUIVOS
// ===============================================

model File {
  id           String   @id @default(cuid())
  originalName String
  fileName     String   @unique
  type         FileType
  size         Int
  mimeType     String
  url          String   @unique
  description  String?

  companyId          String?
  company            Company?            @relation("CompanyFiles", fields: [companyId], references: [id])
  uploadedBy         String?
  uploadedByUser     User?               @relation("UserFiles", fields: [uploadedBy], references: [id])
  document           Document?           @relation("DocumentFile")
  workOrderEvidences WorkOrderEvidence[] @relation("WorkOrderEvidenceFile")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([companyId])
  @@index([uploadedBy])
  @@index([type])
  @@index([fileName])
  @@index([url])
  @@index([createdAt])
  @@index([deletedAt])
}

// ===============================================
// DOCUMENTOS
// ===============================================

model Document {
  id            String                @id @default(cuid())
  recipientType DocumentRecipientType
  description   String?
  status        DocumentStatus        @default(PENDING)

  fileId    String   @unique
  file      File     @relation("DocumentFile", fields: [fileId], references: [id])
  senderId  String
  sender    User     @relation("DocumentSender", fields: [senderId], references: [id])
  companyId String?
  company   Company? @relation("CompanyDocuments", fields: [companyId], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([senderId])
  @@index([recipientType])
  @@index([status])
  @@index([companyId])
  @@index([createdAt])
  @@index([deletedAt])
}

// ===============================================
// NOTIFICAÇÕES
// ===============================================

model Notification {
  id         String  @id @default(cuid())
  title      String
  message    String
  entityType String?
  entityId   String?

  companyId       String?
  company         Company? @relation("CompanyNotifications", fields: [companyId], references: [id])
  createdByUserId String?

  recipients NotificationRecipient[] @relation("NotificationRecipients")
  targets    NotificationTarget[]    @relation("NotificationTargets")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([companyId])
  @@index([entityType])
  @@index([entityId])
  @@index([createdAt])
  @@index([deletedAt])
}

model NotificationRecipient {
  id     String    @id @default(cuid())
  isRead Boolean   @default(false)
  readAt DateTime?

  notificationId String
  notification   Notification @relation("NotificationRecipients", fields: [notificationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([notificationId, userId])
  @@index([userId])
  @@index([notificationId])
  @@index([isRead])
  @@index([readAt])
}

model NotificationGroup {
  id           String                @id @default(cuid())
  name         String
  description  String?
  type         NotificationGroupType
  isActive     Boolean               @default(true)
  roleFilter   Roles?
  sectorFilter String?

  companyId     String
  company       Company                   @relation("CompanyNotificationGroups", fields: [companyId], references: [id])
  members       NotificationGroupMember[] @relation("GroupMembers")
  notifications NotificationTarget[]      @relation("GroupNotifications")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  createdBy String?

  @@index([companyId])
  @@index([type])
  @@index([isActive])
  @@index([roleFilter])
  @@index([deletedAt])
}

model NotificationGroupMember {
  id      String            @id @default(cuid())
  groupId String
  group   NotificationGroup @relation("GroupMembers", fields: [groupId], references: [id], onDelete: Cascade)
  userId  String
  user    User              @relation("UserGroupMemberships", fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  addedBy   String?

  @@unique([groupId, userId])
  @@index([groupId])
  @@index([userId])
}

model NotificationTarget {
  id      String                 @id @default(cuid())
  type    NotificationTargetType
  userId  String?
  roleId  Roles?
  groupId String?

  notificationId String
  notification   Notification       @relation("NotificationTargets", fields: [notificationId], references: [id], onDelete: Cascade)
  targetGroup    NotificationGroup? @relation("GroupNotifications", fields: [groupId], references: [id])

  createdAt DateTime @default(now())

  @@index([notificationId])
  @@index([type])
  @@index([userId])
  @@index([roleId])
  @@index([groupId])
}

// ===============================================
// PUSH NOTIFICATIONS (notificações push)
// ===============================================

model PushSubscription {
  id       String @id @default(cuid())
  endpoint String @unique
  p256dh   String
  auth     String
  userId   String
  user     User   @relation("UserPushSubscriptions", fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([endpoint])
}
