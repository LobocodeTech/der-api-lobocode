# =============================================================================
# DER API — variáveis de ambiente (dev local)
# =============================================================================

# --- App (Nest) ---
PORT=3000
APP_PORT=3000
NODE_ENV=development

# --- Banco local ---
DB_NAME=der-engine-dev
DB_USER=postgres
DB_PASSWORD=postgres
DATABASE_URL="postgresql://postgres:postgres@localhost:3211/der-engine-dev?schema=public"

# --- JWT ---
JWT_SECRET=der_local_dev_secret
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=7d

# --- MinIO (app) ---
MINIO_HOST=localhost
MINIO_PORT=3311
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=password123
MINIO_USE_SSL=false
MINIO_INTERNAL_ENDPOINT=http://localhost:3311
MINIO_ENDPOINT=http://localhost:3311
MINIO_PUBLIC_ENDPOINT=http://localhost:3311
MINIO_BUCKET_NAME=departamento-estadual-rodovias-files
MINIO_CONSOLE_PORT=9001

# --- Stack database (docker-compose.database.yml + scripts/start-database.sh) ---
COMPOSE_DATABASE_PROJECT_NAME=der-api-lobocode-dev-database
DOCKER_NETWORK_NAME=app-net-departamento-estadual-rodovias-dev
DB_CONTAINER_NAME=departamento-estadual-rodovias-db-dev
REDIS_CONTAINER_NAME=departamento-estadual-rodovias-redis-dev
MINIO_CONTAINER_NAME=departamento-estadual-rodovias-minio-dev
POSTGRES_VOLUME_NAME=der-api-lobocode-dev-postgres-data
REDIS_VOLUME_NAME=der-api-lobocode-dev-redis-data
MINIO_VOLUME_NAME=der-api-lobocode-dev-minio-data
DB_HOST_PORT=3211
REDIS_HOST_PORT=3911
MINIO_API_HOST_PORT=3311
MINIO_CONSOLE_HOST_PORT=3312

# --- Backend na VPS (mantido para compatibilidade de scripts) ---
COMPOSE_VPS_STACK_NAME=der-api-vps-dev
BACKEND_CONTAINER_NAME=departamento-estadual-rodovias-backend-dev
VPS_APP_PROJECT_NAME=der-dev
APP_HOST=der-api-dev.lobocode.com.br
APP_DISPLAY_NAME="Departamento de Estradas de Rodagem Dev"
VPS_APP_COMPOSE_FILE=docker/docker-compose.vps-app.yml
VPS_DEFAULT_SERVICE=backend
APP_HOST_EXAMPLE=der-api-dev.seu-dominio.com

# Labels Traefik no app
TRAEFIK_NETWORK=reverse-proxy
TRAEFIK_CERT_RESOLVER=letsencrypt

# --- Observabilidade (opcional) ---
ENABLE_PROMETHEUS_METRICS=false
ENABLE_AUDIT_LOGS=false
PROMETHEUS_METRICS_PREFIX=der_dev_
METRICS_EXPORT_INTERVAL=15s
PROMETHEUS_BASE_URL=http://localhost:9090
GRAFANA_BASE_URL=http://localhost:3000

# --- E-mail / URLs (dev) ---
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
# Alternativa SSL: SMTP_PORT=465 e SMTP_SECURE=true
SMTP_USER=suporte@lobocode.com.br
SMTP_PASS=D3put@d02025
SMTP_FROM=DER <suporte@lobocode.com.br>
SUPPORT_EMAIL=suporte@lobocode.com.br
AUTH_RESET_PASSWORD_URL=https://der-app.lobocode.com.br
FRONTEND_URL=https://der-app.lobocode.com.br
GEOCODING_USER_AGENT=der-api/1.0

# --- Integrações (opcional em dev) ---
ASAAS_API_KEY=
ASAAS_WALLET_ID=
ASAAS_CUSTOMER_ID=
ASAAS_ENVIRONMENT=sandbox
ASAAS_WEBHOOK_URL=http://localhost:3000/asaas/webhooks/payments
ASAAS_WEBHOOK_TOKEN=

# --- Push / VAPID (opcional em dev) ---
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:dev@lobocode.com

# --- OneDrive export (conta fixa; veja docs/ONEDRIVE-EXPORT-SETUP.md) ---
# Reutiliza MICROSOFT_CLIENT_ID / MICROSOFT_CLIENT_SECRET do bloco OAuth Microsoft no .env
MICROSOFT_REFRESH_TOKEN=
ONEDRIVE_TENANT=consumers
ONEDRIVE_FOLDER_PATH=Relatórios
