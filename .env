# =============================================================================
# DER API — variáveis de ambiente (alinhado ao template-nestjs-api-lobocode/.env)
# Não commitar segredos reais em repositório público.
# =============================================================================
# -----------------------------------------------------------------------------
# 0) App + banco (local: ./scripts/deploy.sh database — Postgres localhost:3211)
# -----------------------------------------------------------------------------
# Ajuste DB_NAME se o nome do banco na VPS/volume for outro.
DB_NAME=der-engine
DB_USER=postgres
DB_PASSWORD=K7x9mP2vQnR5sL8wY1zB4cF6hJ0aD3e
PORT=3000
NODE_ENV=development
DATABASE_URL="postgresql://postgres:K7x9mP2vQnR5sL8wY1zB4cF6hJ0aD3e@localhost:3211/der-engine?schema=public"
# --- Docker Compose: stack database (docker-compose.database.yml + start-database.sh) ---
COMPOSE_DATABASE_PROJECT_NAME=der-api-lobocode-database
DOCKER_NETWORK_NAME=app-net-departamento-estadual-rodovias
DB_CONTAINER_NAME=departamento-estadual-rodovias-db
REDIS_CONTAINER_NAME=departamento-estadual-rodovias-redis
MINIO_CONTAINER_NAME=departamento-estadual-rodovias-minio
POSTGRES_VOLUME_NAME=der-api-lobocode-postgres-data
REDIS_VOLUME_NAME=der-api-lobocode-redis-data
MINIO_VOLUME_NAME=der-api-lobocode-minio-data
DB_HOST_PORT=3211
REDIS_HOST_PORT=3911
MINIO_API_HOST_PORT=3311
MINIO_CONSOLE_HOST_PORT=3312
# -----------------------------------------------------------------------------
# 1) Deploy VPS — backend (docker-compose.vps-app.yml)
# Gateway Traefik (uma vez por VPS): traefik/.env.gateway — não duplicar aqui.
# TRAEFIK_NETWORK e TRAEFIK_CERT_RESOLVER devem ser os mesmos do traefik/.env.gateway.
# -----------------------------------------------------------------------------
VPS_APP_PROJECT_NAME=der
COMPOSE_VPS_STACK_NAME=der-api-vps
BACKEND_CONTAINER_NAME=departamento-estadual-rodovias-backend
APP_HOST=der-api.lobocode.com.br
APP_PORT=3000
APP_DISPLAY_NAME="Departamento Estadual Rodovias"
APP_DISPLAY_NAME="Departamento de Estradas de Rodagem"

TRAEFIK_NETWORK=reverse-proxy
TRAEFIK_CERT_RESOLVER=letsencrypt
VPS_APP_COMPOSE_FILE=docker/docker-compose.vps-app.yml
APP_HOST_EXAMPLE=der-api.lobocode.com.br
VPS_DEFAULT_SERVICE=backend
# -----------------------------------------------------------------------------
# 2) JWT
# -----------------------------------------------------------------------------
JWT_SECRET=erxgBVGNyQHwUgXXgBGQzlTdb
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=7d
# -----------------------------------------------------------------------------
# 3) MinIO (compose database: API 3311, console 3312 — mesmo stack que Postgres/Redis)
# Dentro da rede Docker o host é o container; local use localhost nas portas.
# -----------------------------------------------------------------------------
MINIO_HOST=localhost
MINIO_PORT=3311
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=password123
MINIO_USE_SSL=false
# Endpoint interno do cliente MinIO (backend -> servidor MinIO).
# Em produção (docker network): http://minio:9000
MINIO_INTERNAL_ENDPOINT=http://localhost:3311
MINIO_ENDPOINT=http://localhost:3311
# URL pública usada no banco para acesso aos arquivos.
# Em produção, deve apontar para domínio/rota pública do MinIO ou proxy.
MINIO_PUBLIC_ENDPOINT=https://der-api.lobocode.com.br/files
MINIO_BUCKET_NAME=departamento-estadual-rodovias-files
MINIO_CONSOLE_PORT=9001
# Em produção atrás de HTTPS / mesmo host da API, ajuste para URL pública dos arquivos, ex.:
# MINIO_ENDPOINT=https://der-api.lobocode.com.br/files
# MINIO_USE_SSL=true
# -----------------------------------------------------------------------------
# 4) E-mail / URLs (Hostinger Email — Lobocode)
# -----------------------------------------------------------------------------
# Hostinger: SMTP_PORT=465 e SMTP_SECURE=true
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=suporte@lobocode.com.br
SMTP_PASS=D3put@d02025
SMTP_FROM='DER <suporte@lobocode.com.br>'
SUPPORT_EMAIL=suporte@lobocode.com.br
AUTH_RESET_PASSWORD_URL=https://der-app.lobocode.com.br
FRONTEND_URL=https://der-app.lobocode.com.br
GEOCODING_USER_AGENT=der-api/1.0
# -----------------------------------------------------------------------------
# 5) Observabilidade (opcional)
# -----------------------------------------------------------------------------
ENABLE_PROMETHEUS_METRICS=false
ENABLE_AUDIT_LOGS=false
PROMETHEUS_METRICS_PREFIX=der_
METRICS_EXPORT_INTERVAL=15s
PROMETHEUS_BASE_URL=http://localhost:9090
GRAFANA_BASE_URL=http://localhost:3000
# -----------------------------------------------------------------------------
# 6) ASAAS (opcional)
# -----------------------------------------------------------------------------
ASAAS_API_KEY=
ASAAS_WALLET_ID=
ASAAS_CUSTOMER_ID=
ASAAS_ENVIRONMENT=sandbox
ASAAS_WEBHOOK_URL=https://der-api.lobocode.com.br/asaas/webhooks/payments
ASAAS_WEBHOOK_TOKEN=
# -----------------------------------------------------------------------------
