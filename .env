# 10) Integração Work Orders (/integration/work-orders)
# Token compartilhado com a cliente (header Authorization: Bearer ou X-Shared-Token).
# Gere um valor forte: openssl rand -hex 32
# -----------------------------------------------------------------------------
SHARED_API_TOKEN_LOBOCODE_DER=lobocode-der_1K3u2PqUBxXrlw0Jf3J4dJBx54JVVq39JfXv35EoL1Wav0dMX5honFRVxD0UHC6X
# Rate limit da integração (por IP + rota, janela deslizante em memória)
INTEGRATION_RATE_LIMIT_MAX=120
INTEGRATION_RATE_LIMIT_WINDOW_MS=60000
# CORS dedicado do middleware de integração (todas as origens por enquanto)
INTEGRATION_CORS_ALLOW_ALL=true
INTEGRATION_CORS_ALLOWED_ORIGINS=
# CORS global da API (main.ts)
CORS_ALLOW_ALL=true