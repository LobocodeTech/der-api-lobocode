{
  "name": "lobocode-project",
  "version": "0.0.1",
  "description": "",
  "author": "Claiver Almeida de Araújo",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "npm run build && npm run db:init:prod && node dist/src/main",
    "start:with-seed": "npm run build && npm run db:init:prod && npm run prisma:seed && node dist/src/main",
    "start:dev": "npm run db:init:dev && npm run prisma:seed && nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/src/main",
    "docker:dev": "docker compose up",
    "docker:prod": "docker compose -f docker-compose.prod.yml up -d",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "db:init:dev": "npm run prisma:generate && prisma migrate dev --skip-seed",
    "db:init:prod": "npm run prisma:generate && prisma migrate deploy",
    "prisma:generate": "prisma generate",
    "prisma:studio": "prisma studio",
    "prisma:migrate": "prisma migrate dev --name",
    "prisma:seed": "ts-node prisma/seed.ts",
    "prisma:dev": "./scripts/prisma-switch.sh dev",
    "prisma:prod": "./scripts/prisma-switch.sh prod",
    "prisma:erd": "npx prisma generate",
    "dev:setup": "npm run db:init:dev && npm run prisma:seed",
    "prisma:pull": "prisma db pull",
    "prisma:push": "prisma db push",
    "onedrive:oauth-setup": "node scripts/onedrive-oauth-setup.mjs"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@azure/service-bus": "^7.9.5",
    "@casl/ability": "^6.7.3",
    "@casl/prisma": "^1.5.1",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/mapped-types": "*",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/platform-socket.io": "^11.1.6",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/websockets": "^11.1.6",
    "@prisma/client": "^6.14.0",
    "@types/express-session": "^1.18.2",
    "@willsoto/nestjs-prometheus": "^6.0.0",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "express-session": "^1.19.0",
    "jspdf": "^4.2.0",
    "minio": "^8.0.7",
    "multer": "^2.1.1",
    "nest-winston": "^1.10.2",
    "nodemailer": "^8.0.10",
    "or": "^0.2.0",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-microsoft": "^2.1.0",
    "prisma": "^6.14.0",
    "prom-client": "^15.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.1",
    "web-push": "^3.6.7",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.10.7",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/multer": "^1.4.11",
    "@types/node": "^22.10.7",
    "@types/nodemailer": "^8.0.0",
    "@types/passport": "^1.0.17",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/passport-microsoft": "^2.1.1",
    "@types/supertest": "^6.0.2",
    "@types/web-push": "^3.6.4",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-prettier": "^5.5.0",
    "globals": "^16.0.0",
    "jest": "^29.7.0",
    "prettier": "^3.5.3",
    "prisma-erd-generator": "^2.4.2",
    "prisma-json-types-generator": "^3.6.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
